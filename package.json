{
  "name": "daredemo-slot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "日本のパチスロの内部構造（抽選・リール制御・状態機械）を WebUI で設定して遊べるシミュレータ。実在機種の再現ではなく、実機データは一切使用しない。",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:all": "vitest run --mode all",
    "test:watch": "vitest",
    "symbols": "vite-node tools/process-symbols.ts --",
    "symbols:check": "vite-node tools/check-symbols.ts --",
    "panel": "vite-node tools/process-panel.ts --",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "pngjs": "^7.0.0",
    "typescript": "^5.5.0",
    "vite": "^7.3.6",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
